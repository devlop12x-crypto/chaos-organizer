{
  "extends": "airbnb-base",
  "env": {
    "browser": true,
    "es2022": true,
    "jest": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "rules": {
    "no-await-in-loop": "off",
    "no-restricted-syntax": ["error", "LabeledStatement", "WithStatement"],
    "import/no-extraneous-dependencies": [
      "error",
      {
        "devDependencies": [
          "**/webpack.config.js",
          "**/jest.config.js",
          "**/*.test.js"
        ]
      }
    ]
  },
  "ignorePatterns": ["dist/", "coverage/", "node_modules/"]
}
